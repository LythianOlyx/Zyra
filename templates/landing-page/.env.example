# Copy this file to .env and fill in real values before running `zyra dev`.
# Zyra automatically strips any variable WITHOUT the PUBLIC_ prefix from the
# client bundle, so never put secrets behind PUBLIC_.

ZYRA_ENV=development

# Database connection string. Leave empty for static marketing sites.
DATABASE_URL=[[.DatabaseURL]]

# Recipient email address for contact form submissions.
CONTACT_EMAIL=sales@example.com

# Set to "false" to disable OpenTelemetry tracing + Prometheus /metrics.
ZYRA_OBSERVABILITY=[[.EnableObservability]]
