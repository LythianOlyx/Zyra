# Copy this file to .env and fill in real values before running `zyra dev`.
# Zyra automatically strips any variable WITHOUT the PUBLIC_ prefix from the
# client bundle, so never put secrets behind PUBLIC_.

ZYRA_ENV=development

# Database connection string. Leave empty to run without a database (this
# template's admin/users store defaults to an in-memory in-process store).
# postgres: postgres://user:password@localhost:5432/[[.AppName]]?sslmode=disable
# mysql:    user:password@tcp(localhost:3306)/[[.AppName]]
DATABASE_URL=[[.DatabaseURL]]

# Secret used to sign sessions/JWTs. Generate a real one with
# `openssl rand -hex 32` before deploying to production.
JWT_SECRET=dev-insecure-secret-change-in-production

# Seed admin account created at boot (in-memory demo only — see main.go).
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-password-now

# Set to "false" to disable OpenTelemetry tracing + Prometheus /metrics.
ZYRA_OBSERVABILITY=[[.EnableObservability]]
